extends layout
 
block content
  h1= title
 
  div.container-fluid
    div.row
      -
        let Sculptures=results
       
      each Sculptures,index in results
        .col-sm-2
        div.col-sm-2(onclick=`buy(${index})`)
       
          p style: #{Sculptures.Sculptures_style}
          p material : #{Sculptures.Sculptures_material}
          p height: #{Sculptures.Sculptures_height.toFixed(2)}
 
  a(href="/") Back to index
 
    script.
        function buy(index) {
            alert(`You purchased item ${index}`);
        }
 